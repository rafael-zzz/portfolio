{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "lint": "eslint . --ext .js,.ts,.tsx,.astro",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check:all": "npm run lint && npm run test && npm run build && npm run test:e2e",
    "content:translate": "tsx scripts/translate-content.ts",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^5.18.0",
    "preact": "^10.23.2",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0-alpha.23",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "astro-eslint-parser": "^1.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.0.0-alpha.23",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
