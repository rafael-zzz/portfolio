---
import type { Messages } from "@/i18n/schema";
import SectionFrame from "@/shared/ui/SectionFrame.astro";
import SectionHeader from "@/shared/ui/SectionHeader.astro";

interface Props {
  copy: Messages["home"]["experience"];
}

const { copy } = Astro.props;
---

<SectionFrame>
  <SectionHeader title={copy.title} eyebrow={copy.eyebrow} />

  <div class="experience-grid">
    {
      copy.places.map((place) => (
        <article class="experience-card">
          <header class="experience-header">
            <p class="experience-role font-['Departure_Mono']">{place.role}</p>
            <p class="experience-company font-['Departure_Mono']">@ {place.company}</p>
            <p class="experience-period font-['Departure_Mono']">{place.period}</p>
          </header>
          <ul class="experience-list">
            {place.highlights.map((highlight) => (
              <li class="font-['Departure_Mono']">{highlight}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</SectionFrame>

<style>
  .experience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    padding: 1rem;
  }

  .experience-card {
    border: 1px solid rgba(215, 215, 215, 0.24);
    background: linear-gradient(180deg, rgba(4, 8, 12, 0.82), rgba(9, 14, 22, 0.78));
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
  }

  .experience-header {
    border-bottom: 1px solid rgba(215, 215, 215, 0.18);
    padding: 0.8rem 0.9rem;
  }

  .experience-role {
    color: var(--site-link-color);
    font-size: 1rem;
    line-height: 1.4;
  }

  .experience-company {
    color: var(--site-link-color);
    font-size: 0.86rem;
    margin-top: 0.2rem;
  }

  .experience-period {
    color: rgba(220, 220, 220, 0.76);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    margin-top: 0.35rem;
    text-transform: uppercase;
  }

  .experience-list {
    list-style: none;
    padding: 0.85rem 0.9rem 0.95rem;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .experience-list li {
    position: relative;
    color: rgba(232, 245, 255, 0.88);
    font-size: 0.88rem;
    line-height: 1.65;
    padding-left: 1.25rem;
  }

  .experience-list li::before {
    content: ">>";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--site-link-color);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 640px) {
    .experience-grid {
      grid-template-columns: 1fr;
      padding: 0.75rem;
    }
  }
</style>
