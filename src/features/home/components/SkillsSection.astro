---
import type { Messages } from "@/i18n/schema";
import SectionFrame from "@/shared/ui/SectionFrame.astro";
import SectionHeader from "@/shared/ui/SectionHeader.astro";
import LearningToggle from "@/features/home/islands/LearningToggle";
import { coreSkills, learningSkills } from "@/features/home/model/skillsCatalog";

interface Props {
  copy: Messages["home"]["skills"];
}

const { copy } = Astro.props;
---

<SectionFrame>
  <SectionHeader title={copy.title} eyebrow={copy.eyebrow} />

  <div class="skills-container md:grid">
    {
      coreSkills.map((skill) => (
        <div class="skill-card hover-glow">
          <span class="skill-module-id">MOD_{skill.id}</span>
          <p class="text-l font-['Departure_Mono'] skill-title">&gt; {skill.name}</p>
        </div>
      ))
    }
  </div>

  <LearningToggle client:load label={copy.learningLabel} items={learningSkills} />
</SectionFrame>

<style>
  :global(.skills-container) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.7rem;
    padding: 1rem;
  }

  :global(.skill-card) {
    background: linear-gradient(180deg, rgba(5, 9, 15, 0.86), rgba(9, 15, 22, 0.8));
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 0 0 1px rgba(215, 215, 215, 0.08) inset;
    overflow: hidden;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    text-align: left;
    padding: 1.2rem 0.8rem 0.8rem;
    position: relative;
    cursor: default;
  }

  :global(.skill-module-id) {
    position: absolute;
    top: 0.45rem;
    left: 0.45rem;
    color: rgba(220, 220, 220, 0.55);
    font-family: "Departure Mono", monospace;
    font-size: 0.55rem;
    letter-spacing: 0.16em;
  }

  :global(.skill-card:hover) {
    transform: translateY(-2px);
    border-color: var(--site-accent-color);
    background: linear-gradient(180deg, rgba(8, 14, 22, 0.9), rgba(12, 20, 30, 0.85));
  }

  :global(.skill-title) {
    color: #ffffff;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    margin-top: 0.5rem;
  }

  :global(.learning-toggle) {
    background: linear-gradient(180deg, rgba(4, 8, 12, 0.92), rgba(8, 13, 20, 0.92));
    border: 1px solid rgba(215, 215, 215, 0.32);
    color: #ffffff;
    width: calc(100% - 2rem);
    margin: 0 1rem 1rem;
    text-align: center;
    padding: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    cursor: pointer;
  }

  :global(.learning-content) {
    transition: max-height 0.2s ease-out;
  }
</style>
