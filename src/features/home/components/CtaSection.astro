---
import type { Messages } from "@/i18n/schema";

interface Props {
  copy: Messages["home"]["cta"];
}

const { copy } = Astro.props;

const destinations = [
  {
    href: "https://github.com/rafael-zzz",
    label: copy.githubLabel,
    path: "github.com/rafael-zzz",
    eyebrow: "/out/github",
  },
  {
    href: "https://linkedin.com/in/rafael-m-peixoto",
    label: copy.linkedinLabel,
    path: "linkedin.com/rafael-peixoto",
    eyebrow: "/out/linkedin",
  },
];
---

<section class="cta-shell">
  <div class="cta-frame">
    <div class="cta-intro">
      <p class="cta-kicker font-['Departure_Mono']">{copy.title}</p>
      <p class="cta-summary font-['Departure_Mono']">{copy.summary}</p>
    </div>

    <div class="cta-grid">
      {
        destinations.map((destination) => (
          <a href={destination.href} class="cta-panel">
            <div class="cta-copy">
              <p class="cta-panel-kicker font-['Departure_Mono']">{destination.eyebrow}</p>
              <p class="cta-title font-wayfarers">{destination.label}</p>
            </div>

            <div class="cta-destination font-['Departure_Mono']">
              <span class="cta-prompt">&gt;&gt;</span>
              <span class="cta-path">{destination.path}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cta-shell {
    margin-top: 1rem;
  }

  .cta-frame {
    margin: 0 auto;
    max-width: 80rem;
    padding: 0 1rem 1.5rem;
  }

  .cta-intro {
    display: grid;
    gap: 0.45rem;
    margin-bottom: 1rem;
  }

  .cta-kicker {
    color: rgba(220, 220, 220, 0.78);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .cta-summary {
    color: rgba(232, 245, 255, 0.88);
    font-size: 0.94rem;
    line-height: 1.75;
  }

  .cta-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .cta-panel {
    align-items: center;
    background: linear-gradient(180deg, rgba(4, 8, 12, 0.9), rgba(8, 14, 20, 0.9));
    border: 1px solid rgba(215, 215, 215, 0.24);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.05) inset,
      0 16px 30px rgba(0, 0, 0, 0.22);
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) auto;
    padding: 1.1rem 1.2rem;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .cta-panel:hover {
    border-color: rgba(215, 215, 215, 0.42);
    background: linear-gradient(180deg, rgba(6, 10, 14, 0.94), rgba(10, 16, 24, 0.94));
    transform: translateY(-2px);
  }

  .cta-copy {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .cta-panel-kicker {
    color: rgba(220, 220, 220, 0.78);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .cta-title {
    color: #f5fbff;
    font-size: clamp(0.63rem, 1.26vw, 0.945rem);
    line-height: 1.15;
    text-shadow: 0 0 10px rgba(215, 215, 215, 0.12);
  }

  .cta-destination {
    align-items: center;
    border: 1px solid rgba(215, 215, 215, 0.24);
    color: #b7d6ff;
    display: inline-flex;
    gap: 0.55rem;
    letter-spacing: 0.08em;
    padding: 0.75rem 0.9rem;
  }

  .cta-panel:hover .cta-destination {
    background: rgba(215, 215, 215, 0.08);
    color: #ffffff;
  }

  .cta-prompt {
    color: rgba(220, 220, 220, 0.82);
  }

  .cta-path {
    overflow-wrap: anywhere;
  }

  @media (max-width: 900px) {
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .cta-destination {
      justify-content: center;
      width: 100%;
    }
  }
</style>
