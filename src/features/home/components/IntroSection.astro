---
import type { Messages } from "@/i18n/schema";
import SectionFrame from "@/shared/ui/SectionFrame.astro";
import SectionHeader from "@/shared/ui/SectionHeader.astro";

interface Props {
  copy: Messages["home"]["hero"];
}

const { copy } = Astro.props;
---

<SectionFrame class="intro-section">
  <SectionHeader title={copy.title} eyebrow="/profile/boot" />
  <div class="content-container">
    <div class="mx-auto max-w-7xl px-3">
      <div class="intro-layout">
        <div class="intro-copy-panel">
          <p class="intro-copy-meta font-['Departure_Mono']">STATUS: ACTIVE</p>
          <h1 class="intro-header font-['ZX_Spectrum-7'] mb-3">
            <span class="inline-block">{copy.heading}</span>
          </h1>
          <p class="intro-description font-['Departure_Mono']">
            {copy.description}
          </p>
        </div>

        <div class="intro-visual-panel">
          <picture class="intro-visual-frame">
            <a href="https://linkedin.com/in/rafael-m-peixoto">
              <img
                src="/images/blackhole.gif"
                alt={copy.imageAlt}
                width="300"
                height="300"
                class="w-full h-full object-cover"
                loading="eager"
                decoding="async"
              />
            </a>
          </picture>
        </div>
      </div>
    </div>
  </div>
</SectionFrame>

<style>
  .content-container {
    padding: 1.2rem 0 1.4rem;
  }

  .intro-layout {
    display: grid;
    gap: 1rem;
    align-items: stretch;
    grid-template-columns: minmax(0, 1.15fr) minmax(260px, 0.85fr);
  }

  .intro-copy-panel,
  .intro-visual-panel {
    background: rgba(3, 6, 11, 0.54);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 0 0 1px rgba(144, 248, 255, 0.06) inset;
    padding: 1rem;
    position: relative;
  }

  .intro-copy-meta {
    color: rgba(156, 255, 204, 0.78);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    margin-bottom: 0.7rem;
    text-transform: uppercase;
  }

  .intro-header {
    color: #ffffff;
    font-size: 2.8rem;
    line-height: 1;
    text-shadow: 0 0 14px rgba(144, 248, 255, 0.12);
  }

  .intro-description {
    color: rgba(226, 241, 255, 0.9);
    font-size: 1rem;
    line-height: 1.9;
  }

  .intro-visual-panel {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .intro-visual-frame {
    aspect-ratio: 1;
    border: 1px solid rgba(144, 248, 255, 0.26);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.07) inset;
    overflow: hidden;
    position: relative;
    width: min(100%, 360px);
  }

  .intro-visual-frame::after {
    content: "VISUAL_FEED";
    position: absolute;
    left: 0.6rem;
    bottom: 0.6rem;
    z-index: 1;
    color: rgba(255, 255, 255, 0.76);
    font-family: 'Departure Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    background: rgba(0, 0, 0, 0.6);
    padding: 0.2rem 0.35rem;
  }

  @media (max-width: 900px) {
    .intro-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .intro-header {
      font-size: 2.15rem;
    }

    .content-container {
      padding-top: 0.95rem;
    }
  }
</style>
