---
import type { Messages } from "@/i18n/schema";
import type { HomeBlogPreview } from "@/features/home/model/blogPreviews";
import SectionFrame from "@/shared/ui/SectionFrame.astro";
import SectionHeader from "@/shared/ui/SectionHeader.astro";
import RetroCard from "@/shared/ui/RetroCard.astro";

interface Props {
  copy: Messages["home"]["blog"];
  posts: HomeBlogPreview[];
}

const { copy, posts } = Astro.props;
const isSinglePost = posts.length === 1;
---

<SectionFrame class="blog-preview-section">
  <SectionHeader title={copy.title} eyebrow={copy.eyebrow} />

  <div class="blog-preview-summary font-['Departure_Mono']">
    {copy.summary}
  </div>

  {
    posts.length > 0 ? (
      <div class:list={["blog-preview-grid", isSinglePost && "blog-preview-grid-single"]}>
        {posts.map((post) => (
          <RetroCard class="blog-preview-card">
            <article class="blog-preview-card-body">
              <div class="blog-preview-meta font-['Departure_Mono']">
                <span>ENTRY_LOG</span>
                <time datetime={post.publishedAt.toISOString()}>{post.publishedDateLabel}</time>
              </div>
              <h2 class="blog-preview-title font-['ZX_Spectrum-7']">{post.title}</h2>
              <p class="blog-preview-description font-['Departure_Mono']">{post.description}</p>
              <a class="blog-preview-link font-['Departure_Mono']" href={post.href}>
                {copy.readMoreLabel}
              </a>
            </article>
          </RetroCard>
        ))}
      </div>
    ) : (
      <div class="blog-preview-empty font-['Departure_Mono']">
        <span class="blog-preview-empty-prompt">C:\&gt;</span> {copy.emptyLabel}
      </div>
    )
  }
</SectionFrame>

<style>
  .blog-preview-section {
    margin-top: 1rem;
  }

  .blog-preview-summary {
    color: rgba(214, 246, 255, 0.92);
    font-size: 0.92rem;
    letter-spacing: 0.04em;
    line-height: 1.7;
    padding: 1rem 1.2rem 0;
    text-transform: uppercase;
  }

  .blog-preview-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    padding: 1rem 1.1rem 1.2rem;
  }

  .blog-preview-grid-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .blog-preview-card {
    min-height: 100%;
  }

  .blog-preview-card-body {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 1rem;
    gap: 0.8rem;
  }

  .blog-preview-meta {
    align-items: center;
    color: rgba(156, 255, 226, 0.9);
    display: flex;
    font-size: 0.7rem;
    justify-content: space-between;
    letter-spacing: 0.12em;
    padding-bottom: 0.65rem;
    text-transform: uppercase;
    border-bottom: 1px dashed rgba(156, 255, 226, 0.38);
  }

  .blog-preview-title {
    color: #ffffff;
    font-size: 1.3rem;
    line-height: 1.2;
  }

  .blog-preview-description {
    color: rgba(232, 245, 255, 0.88);
    font-size: 0.92rem;
    line-height: 1.7;
    flex: 1;
  }

  .blog-preview-link {
    align-self: flex-start;
    border: 1px solid rgba(144, 248, 255, 0.7);
    color: #90f8ff;
    letter-spacing: 0.12em;
    padding: 0.55rem 0.8rem;
    text-transform: uppercase;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .blog-preview-link:hover {
    background: rgba(144, 248, 255, 0.14);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .blog-preview-empty {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(232, 245, 255, 0.82);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    margin: 1rem 1.1rem 1.2rem;
    padding: 1rem 0.25rem 0;
    text-transform: uppercase;
  }

  .blog-preview-empty-prompt {
    color: #90f8ff;
  }

  @media (max-width: 640px) {
    .blog-preview-summary {
      font-size: 0.82rem;
      padding: 0.9rem 0.9rem 0;
    }

    .blog-preview-grid {
      padding: 0.9rem;
    }

    .blog-preview-title {
      font-size: 1.15rem;
    }
  }
</style>
