---
import SiteHead from "@/features/chrome/components/SiteHead.astro";
import TopNavigation from "@/features/chrome/components/TopNavigation.astro";
import Sidebar from "@/features/chrome/components/Sidebar.astro";
import FooterBar from "@/features/chrome/components/FooterBar.astro";
import MusicPlayer from "@/features/chrome/components/MusicPlayer.astro";
import { ClientRouter } from "astro:transitions";
import { HTML_LANG_BY_LOCALE, type Locale } from "@/i18n/config";
import type { Messages } from "@/i18n/schema";
import type { LocalizedRouteMeta, RouteKey } from "@/i18n/routes";

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  messages: Messages;
  routeMeta: LocalizedRouteMeta;
}

const { locale, routeKey, messages, routeMeta } = Astro.props;
---

<html
  lang={HTML_LANG_BY_LOCALE[locale]}
  class="selection:bg-retro-primary selection:text-retro-dark"
>
  <head>
    <ClientRouter />
    <SiteHead
      locale={locale}
      headCopy={messages.head}
      canonicalPath={routeMeta.canonicalPath}
      languagePaths={routeMeta.languagePaths}
      xDefaultPath={routeMeta.xDefaultPath}
    />
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap");
    </style>
  </head>
  <body class="text-white bg-black">
    <div class="retro-grid-bg"></div>
    <div class="scanline"></div>
    <div class="crt-overlay"></div>
    <TopNavigation
      locale={locale}
      routeKey={routeKey}
      copy={messages.navigation}
      languagePaths={routeMeta.languagePaths}
    />
    <Sidebar locale={locale} copy={messages.sidebar} />
    <div class="lg:pl-48">
      <main class="mx-auto max-w-7xl px-4 pt-32 md:pt-24 sm:pt-20">
        <nav-interceptor>
          <slot />
        </nav-interceptor>
      </main>
      <FooterBar copy={messages.footer} />
    </div>
    <MusicPlayer transition:persist />

    <script>
      import { navigate } from "astro:transitions/client";

      class NavInterceptor extends HTMLElement {
        connectedCallback() {
          this.handleGlobalClick = this.handleGlobalClick.bind(this);
          document.addEventListener("click", this.handleGlobalClick);
        }

        disconnectedCallback() {
          document.removeEventListener("click", this.handleGlobalClick);
        }

        private handleGlobalClick(event: MouseEvent) {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }

          const target = event.target as HTMLElement;
          if (!target || !(target instanceof Element)) {
            return;
          }

          const link = target.closest("a") as HTMLAnchorElement | null;
          if (!link) {
            return;
          }

          if (
            link.hasAttribute("download") ||
            link.dataset.astroReload !== undefined ||
            link.dataset.noNav !== undefined
          ) {
            return;
          }

          const href = link.getAttribute("href");
          if (
            !href ||
            href.startsWith("#") ||
            href.startsWith("mailto:") ||
            href.startsWith("tel:")
          ) {
            return;
          }

          if (link.target && link.target !== "_self") {
            return;
          }

          let url;
          try {
            url = new URL(link.href, window.location.href);
          } catch {
            return;
          }

          if (url.origin !== window.location.origin) {
            return;
          }

          event.preventDefault();
          void navigate(`${url.pathname}${url.search}${url.hash}`);
        }
      }

      if (!customElements.get("nav-interceptor")) {
        customElements.define("nav-interceptor", NavInterceptor);
      }
    </script>
  </body>
</html>
