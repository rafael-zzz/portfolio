---
const rootId = "stereo-player-root";
const playerId = "stereo-youtube-player";
const volumeId = "stereo-volume";
const toggleId = "stereo-toggle";
const rewindId = "stereo-rewind";
const skipId = "stereo-skip";
const trackId = "stereo-track";
const statusId = "stereo-status";
const closeId = "stereo-close";
const reopenId = "stereo-reopen";
const genreId = "stereo-genre";
---

<stereo-player
  id={rootId}
  data-stereo-root="persistent"
  transition:persist
  class="stereo-player"
  aria-label="Music player"
>
  <div class="stereo-shell">
    <div class="stereo-header">
      <p class="stereo-title font-wayfarers">STEREO DECK</p>
      <button
        id={closeId}
        type="button"
        class="stereo-close font-['Departure_Mono']"
        aria-label="Close music player"
      >
        Close
      </button>
    </div>
    <p id={trackId} class="stereo-track font-['Departure_Mono']">Loading track...</p>
    <div class="stereo-controls">
      <button
        id={rewindId}
        type="button"
        class="stereo-button font-['Departure_Mono']"
        aria-label="Play previous track"
      >
        Rewind
      </button>
      <button
        id={toggleId}
        type="button"
        class="stereo-button font-['Departure_Mono']"
        aria-label="Play or pause track"
      >
        Pause
      </button>
      <button
        id={skipId}
        type="button"
        class="stereo-button font-['Departure_Mono']"
        aria-label="Play next track"
      >
        Skip
      </button>
    </div>
    <div class="stereo-mix-row">
      <span id="stereo-genre-label" class="stereo-genre-label font-['Departure_Mono']">GENRE</span>
      <select
        id={genreId}
        class="stereo-genre-select font-['Departure_Mono']"
        aria-labelledby="stereo-genre-label"></select>
      <span id="stereo-volume-label" class="stereo-volume-label font-['Departure_Mono']">VOL</span>
      <div class="stereo-slider-container">
        <input
          id={volumeId}
          type="range"
          min="0"
          max="100"
          value="30"
          class="stereo-volume"
          aria-labelledby="stereo-volume-label"
        />
      </div>
    </div>
    <p id={statusId} class="stereo-status font-['Departure_Mono']">Loading...</p>
  </div>
  <button
    id={reopenId}
    type="button"
    class="stereo-reopen font-['Departure_Mono']"
    aria-label="Open music player"
  >
    Open player
  </button>
  <div id={playerId} class="stereo-hidden-player" aria-hidden="true"></div>
</stereo-player>

<script is:inline>
  (function() {
    const PLAYLISTS = {
      electronic: {
        label: "Electronic",
        tracks: [
          { title: "Daft Punk - Get Lucky", videoId: "5NV6Rdv1a3I" },
          { title: "Gorillaz - Feel Good Inc.", videoId: "HyHNuVaZJ-k" },
          { title: "Kavinsky - Nightcall", videoId: "MV_3Dpw-BRY" },
          { title: "Jamiroquai - Virtual Insanity", videoId: "4JkIs37a2JE" },
          { title: "The Weeknd - Blinding Lights", videoId: "4NRXx6U8ABQ" },
          { title: "Tame Impala - Let It Happen", videoId: "pFptt7Cargc" },
          { title: "The Strokes - Reptilia", videoId: "b8-tXG8KrWs" },
        ],
      },
      nuMetal: {
        label: "Nu Metal",
        tracks: [
          { title: "Tool - Lateralus", videoId: "Y7JG63IuaWs" },
          { title: "Linkin Park - Papercut", videoId: "2K-evRnwcSc" },
          { title: "Tool - Schism", videoId: "80RtBeB61LE" },
          { title: "Tool - Sober", videoId: "ouVedNg-6WQ" },
          { title: "Tool - Vicarious", videoId: "N26N7lQHNW8" },
          { title: "Linkin Park - Numb", videoId: "kXYiU_JCYtU" },
          { title: "Limp Bizkit - Break Stuff", videoId: "ZpUYjpKg9KY" },
        ],
      },
    };

    const PLAYLIST_IDS = Object.keys(PLAYLISTS);
    const STORAGE_KEY = "stereoPlayerState";
    const DEFAULT_VOLUME = 30;
    const MIN_VOLUME = 0;
    const MAX_VOLUME = 100;
    const MOBILE_MEDIA_QUERY = "(max-width: 640px)";

    class StereoPlayer extends HTMLElement {
      constructor() {
        super();
        this.player = null;
        this.state = this.loadState() || this.createInitialState();
        this.statusOverride = null;
        this.ytHooked = false;
        this.scriptInjected = false;
        this.listenersInitialized = false;

        this.onBeforeSwap = this.onBeforeSwap.bind(this);
        this.onAfterSwap = this.onAfterSwap.bind(this);
        this.onVisibilityChange = this.onVisibilityChange.bind(this);
      }

      connectedCallback() {
        window.__stereoPlayer = this;
        // Wait for children to be parsed if not already present
        if (this.querySelector("#stereo-volume")) {
          this.init();
        } else {
          requestAnimationFrame(() => this.init());
        }
      }

      init() {
        this.bootstrap();
        this.setupListeners();
      }

      createInitialState() {
        return {
          playlistId: PLAYLIST_IDS[0] || "electronic",
          trackIndex: 0,
          volume: DEFAULT_VOLUME,
          isPlaying: false,
          resumeTime: 0,
          isClosed: false,
        };
      }

      loadState() {
        try {
          const raw = window.localStorage.getItem(STORAGE_KEY);
          if (!raw) return null;
          return this.normalizeState(JSON.parse(raw));
        } catch (e) {
          return null;
        }
      }

      normalizeState(candidate) {
        const base = this.createInitialState();
        if (!candidate || typeof candidate !== "object") return base;

        const playlistId = PLAYLIST_IDS.includes(candidate.playlistId)
          ? candidate.playlistId
          : base.playlistId;
        const tracks = PLAYLISTS[playlistId]?.tracks || [];

        return {
          playlistId,
          trackIndex:
            tracks.length > 0
              ? (((candidate.trackIndex || 0) % tracks.length) + tracks.length) % tracks.length
              : 0,
          volume: Math.min(MAX_VOLUME, Math.max(MIN_VOLUME, Number(candidate.volume) || 0)),
          isPlaying: Boolean(candidate.isPlaying),
          resumeTime: Math.max(0, Number(candidate.resumeTime) || 0),
          isClosed: Boolean(candidate.isClosed),
        };
      }

      persistState() {
        try {
          window.localStorage.setItem(STORAGE_KEY, JSON.stringify(this.state));
        } catch (e) {}
      }

      getNodes() {
        return {
          playerNode: this.querySelector("#stereo-youtube-player"),
          volumeNode: this.querySelector("#stereo-volume"),
          toggleNode: this.querySelector("#stereo-toggle"),
          rewindNode: this.querySelector("#stereo-rewind"),
          skipNode: this.querySelector("#stereo-skip"),
          trackNode: this.querySelector("#stereo-track"),
          statusNode: this.querySelector("#stereo-status"),
          closeNode: this.querySelector("#stereo-close"),
          reopenNode: this.querySelector("#stereo-reopen"),
          genreNode: this.querySelector("#stereo-genre"),
        };
      }

      bootstrap() {
        this.syncUI();

        if (window.YT && window.YT.Player) {
          this.mountPlayer();
        } else {
          if (!this.ytHooked) {
            const prev = window.onYouTubeIframeAPIReady;
            window.onYouTubeIframeAPIReady = () => {
              if (typeof prev === "function") prev();
              this.mountPlayer();
            };
            this.ytHooked = true;
          }

          if (!this.scriptInjected) {
            const script = document.createElement("script");
            script.src = "https://www.youtube.com/iframe_api";
            document.head.appendChild(script);
            this.scriptInjected = true;
          }
        }
      }

      setupListeners() {
        if (this.listenersInitialized) return;

        this.addEventListener("input", (e) => {
          if (e.target.id === "stereo-volume") {
            this.setVolume(Number(e.target.value));
          }
        });

        this.addEventListener("click", (e) => {
          const btn = e.target.closest("button");
          if (!btn) return;

          if (btn.id === "stereo-toggle") this.togglePlayback();
          if (btn.id === "stereo-rewind") this.jumpTrack(-1);
          if (btn.id === "stereo-skip") this.jumpTrack(1);
          if (btn.id === "stereo-close") this.closePlayer();
          if (btn.id === "stereo-reopen") this.reopenPlayer();
        });

        this.addEventListener("change", (e) => {
          if (e.target.id === "stereo-genre") {
            this.changePlaylist(e.target.value);
          }
        });

        document.addEventListener("astro:before-swap", this.onBeforeSwap);
        document.addEventListener("astro:after-swap", this.onAfterSwap);
        window.addEventListener("resize", () => this.applyVisibility());
        document.addEventListener("visibilitychange", this.onVisibilityChange);
        
        this.listenersInitialized = true;
      }

      onBeforeSwap() {
        this.snapshot();
      }

      onAfterSwap() {
        const wasPlaying = this.state.isPlaying;
        this.syncUI();
        this.state.isPlaying = wasPlaying;
        this.mountPlayer();

        if (
          wasPlaying &&
          this.player &&
          typeof this.player.playVideo === "function" &&
          this.player.getPlayerState() !== window.YT.PlayerState.PLAYING
        ) {
          this.player.playVideo();
        }
      }

      onVisibilityChange() {
        if (document.visibilityState === "hidden") this.snapshot();
      }

      mountPlayer() {
        const { playerNode } = this.getNodes();
        if (!playerNode) return;

        if (this.player && typeof this.player.getPlayerState === "function") {
          this.syncIsPlayingFromAPI();
          return;
        }

        if (!window.YT || !window.YT.Player) return;

        const tracks = PLAYLISTS[this.state.playlistId]?.tracks || [];
        const track = tracks[this.state.trackIndex];
        if (!track) return;

        this.player = new window.YT.Player(playerNode, {
          height: "1",
          width: "1",
          videoId: track.videoId,
          playerVars: {
            autoplay: 0,
            controls: 0,
            disablekb: 1,
            fs: 0,
            iv_load_policy: 3,
            modestbranding: 1,
            playsinline: 1,
            rel: 0,
          },
          events: {
            onReady: () => {
              this.player.setVolume(this.state.volume);
              this.loadTrack(this.state.trackIndex, {
                autoplay: this.state.isPlaying,
                startAtSeconds: this.state.resumeTime,
              });
            },
            onStateChange: (event) => {
              if (event.data === window.YT.PlayerState.PLAYING) {
                this.state.isPlaying = true;
                this.statusOverride = null;
                this.syncUI();
                this.persistState();
              } else if (event.data === window.YT.PlayerState.PAUSED || event.data === window.YT.PlayerState.CUED) {
                this.state.isPlaying = false;
                this.syncUI();
                this.snapshot();
              } else if (event.data === window.YT.PlayerState.ENDED) {
                this.jumpTrack(1);
              }
            },
          },
        });
      }

      syncUI() {
        const nodes = this.getNodes();
        if (nodes.volumeNode) nodes.volumeNode.value = String(this.state.volume);

        if (nodes.genreNode) {
          if (nodes.genreNode.options.length !== PLAYLIST_IDS.length) {
            nodes.genreNode.innerHTML = "";
            PLAYLIST_IDS.forEach((id) => {
              const opt = document.createElement("option");
              opt.value = id;
              opt.textContent = PLAYLISTS[id]?.label || id;
              nodes.genreNode.appendChild(opt);
            });
          }
          nodes.genreNode.value = this.state.playlistId;
        }

        const tracks = PLAYLISTS[this.state.playlistId]?.tracks || [];
        const track = tracks[this.state.trackIndex];
        if (nodes.trackNode) {
          nodes.trackNode.textContent = track?.title || "No track";
          nodes.trackNode.style.color = this.state.isPlaying ? "var(--site-accent-color)" : "#888";
        }

        if (nodes.toggleNode) nodes.toggleNode.textContent = this.state.isPlaying ? "Pause" : "Play";

        if (nodes.statusNode) {
          if (this.statusOverride) {
            nodes.statusNode.textContent = this.statusOverride;
          } else {
            nodes.statusNode.textContent = this.state.isPlaying
              ? `Playing: ${track?.title}`
              : `Ready: ${track?.title}`;
          }
          nodes.statusNode.style.opacity = this.state.isPlaying ? "1" : "0.6";
        }

        this.applyVisibility();
      }

      syncIsPlayingFromAPI() {
        if (!this.player || !window.YT || !window.YT.PlayerState || typeof this.player.getPlayerState !== "function")
          return;
        const s = this.player.getPlayerState();
        if (s === window.YT.PlayerState.PLAYING || s === window.YT.PlayerState.BUFFERING) {
          this.state.isPlaying = true;
        } else if (
          s === window.YT.PlayerState.PAUSED ||
          s === window.YT.PlayerState.CUED ||
          s === window.YT.PlayerState.ENDED
        ) {
          this.state.isPlaying = false;
        }
        this.syncUI();
      }

      applyVisibility() {
        const isMobile = window.matchMedia(MOBILE_MEDIA_QUERY).matches;
        if (!isMobile) {
          this.state.isClosed = false;
          this.removeAttribute("data-stereo-closed");
        } else if (this.state.isClosed) {
          this.setAttribute("data-stereo-closed", "true");
        } else {
          this.removeAttribute("data-stereo-closed");
        }
      }

      setVolume(v) {
        this.state.volume = Math.min(MAX_VOLUME, Math.max(MIN_VOLUME, v));
        if (this.player && typeof this.player.setVolume === "function") {
          this.player.setVolume(this.state.volume);
        }
        this.persistState();
      }

      snapshot() {
        if (this.player && typeof this.player.getCurrentTime === "function") {
          this.state.resumeTime = Number(this.player.getCurrentTime()) || 0;
        }
        this.syncIsPlayingFromAPI();
        this.persistState();
      }

      loadTrack(index, options = {}) {
        const tracks = PLAYLISTS[this.state.playlistId]?.tracks || [];
        if (!tracks.length) return;

        this.state.trackIndex = ((index % tracks.length) + tracks.length) % tracks.length;
        this.state.resumeTime = options.startAtSeconds || 0;
        this.persistState();
        this.syncUI();

        if (!this.player) return;
        const track = tracks[this.state.trackIndex];
        const req =
          this.state.resumeTime > 0
            ? { videoId: track.videoId, startSeconds: this.state.resumeTime }
            : track.videoId;

        if (options.autoplay) {
          this.player.loadVideoById(req);
        } else {
          if (typeof this.player.cueVideoById === "function") {
            this.player.cueVideoById(req);
          } else {
            this.player.loadVideoById(req);
            this.player.pauseVideo();
          }
        }
      }

      jumpTrack(step) {
        this.statusOverride = null;
        this.loadTrack(this.state.trackIndex + step, {
          autoplay: this.state.isPlaying,
          startAtSeconds: 0,
        });
      }

      changePlaylist(id) {
        if (!PLAYLIST_IDS.includes(id)) return;
        this.state.playlistId = id;
        this.state.trackIndex = 0;
        this.state.resumeTime = 0;
        this.statusOverride = null;
        this.loadTrack(0, { autoplay: this.state.isPlaying, startAtSeconds: 0 });
      }

      togglePlayback() {
        if (!this.player) return;
        if (this.state.isPlaying) {
          this.player.pauseVideo();
        } else {
          this.player.playVideo();
        }
      }

      closePlayer() {
        this.state.isClosed = true;
        this.applyVisibility();
        this.persistState();
      }

      reopenPlayer() {
        this.state.isClosed = false;
        this.statusOverride = null;
        this.applyVisibility();
        this.syncUI();
        this.persistState();
      }
    }

    if (!customElements.get("stereo-player")) {
      customElements.define("stereo-player", StereoPlayer);
    }
  })();
</script>

<style>
  .stereo-player {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 55;
    width: min(23rem, calc(100vw - 2rem));
    display: block;
  }

  .stereo-shell {
    border: 1px solid rgba(215, 215, 215, 0.48);
    background:
      linear-gradient(180deg, rgba(4, 7, 10, 0.97), rgba(11, 17, 24, 0.95)),
      radial-gradient(circle at top, rgba(215, 215, 215, 0.16), transparent 50%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08) inset,
      0 0 22px rgba(var(--site-accent-rgb), 0.12),
      0 18px 30px rgba(0, 0, 0, 0.36);
    padding: 0.85rem;
    position: relative;
    overflow: hidden;
  }

  .stereo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .stereo-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.05) 0,
      rgba(255, 255, 255, 0.05) 1px,
      transparent 1px,
      transparent 3px
    );
    background-size: 100% 3px;
    opacity: 0.08;
    pointer-events: none;
  }

  .stereo-title {
    color: #ffffff;
    font-size: 0.515rem;
    letter-spacing: 0.14em;
    margin: 0;
  }

  .stereo-track {
    color: var(--site-accent-color);
    font-size: 0.74rem;
    margin-bottom: 0.65rem;
    min-height: 1.15rem;
    background: rgba(0, 0, 0, 0.3);
    padding: 0.4rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .stereo-controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    gap: 0.55rem;
  }

  .stereo-button {
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #f5fbff;
    background: rgba(255, 255, 255, 0.05);
    font-size: 0.68rem;
    line-height: 1;
    padding: 0.5rem 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .stereo-button:hover {
    color: #ffffff;
    border-color: rgba(215, 215, 215, 0.5);
    background: rgba(215, 215, 215, 0.1);
  }

  .stereo-close,
  .stereo-reopen {
    border: 1px solid rgba(255, 255, 255, 0.28);
    color: #f5fbff;
    background: rgba(255, 255, 255, 0.08);
    font-size: 0.62rem;
    line-height: 1;
    padding: 0.35rem 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .stereo-mix-row {
    margin-top: 0.75rem;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 0.6rem;
  }

  .stereo-genre-label,
  .stereo-volume-label {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .stereo-genre-select {
    width: 100%;
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    padding: 0.25rem 0.35rem;
    font-size: 0.65rem;
    line-height: 1.2;
  }

  .stereo-slider-container {
    display: flex;
    align-items: center;
    height: 1.5rem;
  }

  .stereo-volume {
    -webkit-appearance: none;
    width: 100%;
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    outline: none;
    margin: 0;
  }

  .stereo-volume::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 20px;
    background: #d1d1d1;
    border: 1px solid #888;
    cursor: pointer;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
  }

  .stereo-volume::-moz-range-thumb {
    width: 12px;
    height: 20px;
    background: #d1d1d1;
    border: 1px solid #888;
    cursor: pointer;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
  }

  .stereo-status {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    min-height: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.5rem;
  }

  .stereo-hidden-player {
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    position: absolute;
  }

  @media (max-width: 1024px) {
    .stereo-player {
      bottom: 0.75rem;
      right: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    .stereo-shell {
      padding: 0.65rem;
    }

    .stereo-close {
      display: inline-flex;
    }

    .stereo-reopen {
      width: 100%;
      display: none;
    }

    .stereo-player[data-stereo-closed="true"] .stereo-shell {
      display: none;
    }

    .stereo-player[data-stereo-closed="true"] .stereo-reopen {
      display: flex;
    }
  }
</style>
