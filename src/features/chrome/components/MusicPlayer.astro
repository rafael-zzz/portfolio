---
const rootId = "stereo-player-root";
const playerId = "stereo-youtube-player";
const volumeId = "stereo-volume";
const toggleId = "stereo-toggle";
const rewindId = "stereo-rewind";
const skipId = "stereo-skip";
const trackId = "stereo-track";
const statusId = "stereo-status";
const closeId = "stereo-close";
const reopenId = "stereo-reopen";
const genreId = "stereo-genre";
---

<section
  id={rootId}
  data-stereo-root="persistent"
  transition:persist
  class="stereo-player"
  aria-label="Music player"
>
  <div class="stereo-shell">
    <div class="stereo-header">
      <p class="stereo-title font-wayfarers">STEREO DECK</p>
      <button
        id={closeId}
        type="button"
        class="stereo-close font-['Departure_Mono']"
        aria-label="Close music player"
      >
        Close
      </button>
    </div>
    <p id={trackId} class="stereo-track font-['Departure_Mono']">Loading track...</p>
    <div class="stereo-controls">
      <button
        id={rewindId}
        type="button"
        class="stereo-button font-['Departure_Mono']"
        aria-label="Play previous track"
      >
        Rewind
      </button>
      <button
        id={toggleId}
        type="button"
        class="stereo-button font-['Departure_Mono']"
        aria-label="Play or pause track"
      >
        Pause
      </button>
      <button
        id={skipId}
        type="button"
        class="stereo-button font-['Departure_Mono']"
        aria-label="Play next track"
      >
        Skip
      </button>
    </div>
    <div class="stereo-mix-row">
      <span id="stereo-genre-label" class="stereo-genre-label font-['Departure_Mono']">GENRE</span>
      <select
        id={genreId}
        class="stereo-genre-select font-['Departure_Mono']"
        aria-labelledby="stereo-genre-label"></select>
      <span id="stereo-volume-label" class="stereo-volume-label font-['Departure_Mono']">VOL</span>
      <input
        id={volumeId}
        type="range"
        min="0"
        max="100"
        value="30"
        class="stereo-volume"
        aria-labelledby="stereo-volume-label"
      />
    </div>
    <p id={statusId} class="stereo-status font-['Departure_Mono']">Loading...</p>
  </div>
  <button
    id={reopenId}
    type="button"
    class="stereo-reopen font-['Departure_Mono']"
    aria-label="Open music player"
  >
    Open player
  </button>
  <div id={playerId} class="stereo-hidden-player" aria-hidden="true"></div>
</section>

<script is:inline>
  const PLAYER_DOM_IDS = {
    root: "stereo-player-root",
    player: "stereo-youtube-player",
    volume: "stereo-volume",
    toggle: "stereo-toggle",
    rewind: "stereo-rewind",
    skip: "stereo-skip",
    track: "stereo-track",
    status: "stereo-status",
    close: "stereo-close",
    reopen: "stereo-reopen",
    genre: "stereo-genre",
  };

  const PLAYLISTS = {
    electronic: {
      label: "Electronic",
      tracks: [
        { title: "Daft Punk - Get Lucky", videoId: "5NV6Rdv1a3I" },
        { title: "Gorillaz - Feel Good Inc.", videoId: "HyHNuVaZJ-k" },
        { title: "Kavinsky - Nightcall", videoId: "MV_3Dpw-BRY" },
        { title: "Jamiroquai - Virtual Insanity", videoId: "4JkIs37a2JE" },
        { title: "The Weeknd - Blinding Lights", videoId: "4NRXx6U8ABQ" },
        { title: "Tame Impala - Let It Happen", videoId: "pFptt7Cargc" },
        { title: "The Strokes - Reptilia", videoId: "b8-tXG8KrWs" },
      ],
    },
    nuMetal: {
      label: "Nu Metal",
      tracks: [
        { title: "Tool - Lateralus", videoId: "Y7JG63IuaWs" },
        { title: "Linkin Park - Papercut", videoId: "2K-evRnwcSc" },
        { title: "Tool - Schism", videoId: "80RtBeB61LE" },
        { title: "Tool - Sober", videoId: "ouVedNg-6WQ" },
        { title: "Tool - Vicarious", videoId: "N26N7lQHNW8" },
        { title: "Linkin Park - Numb", videoId: "kXYiU_JCYtU" },
        { title: "Limp Bizkit - Break Stuff", videoId: "ZpUYjpKg9KY" },
      ],
    },
  };

  const PLAYLIST_IDS = Object.keys(PLAYLISTS);
  const STORAGE_KEY = "stereoPlayerState";
  const DEFAULT_VOLUME = 30;
  const MIN_VOLUME = 0;
  const MAX_VOLUME = 100;
  const MOBILE_MEDIA_QUERY = "(max-width: 640px)";
  const GLOBAL_KEY = "__stereoPlayer";

  const createState = () => ({
    playlistId: PLAYLIST_IDS[0] ?? "electronic",
    trackIndex: 0,
    volume: DEFAULT_VOLUME,
    isPlaying: false,
    resumeTime: 0,
    isClosed: false,
  });

  const normalizePlaylistId = (playlistId) =>
    PLAYLIST_IDS.includes(playlistId) ? playlistId : PLAYLIST_IDS[0] ?? "electronic";

  const getTracks = (playlistId) => PLAYLISTS[playlistId]?.tracks ?? [];

  const normalizeTrackIndex = (playlistId, index) => {
    const tracks = getTracks(playlistId);
    if (!tracks.length) {
      return 0;
    }

    if (!Number.isInteger(index)) {
      return 0;
    }

    return ((index % tracks.length) + tracks.length) % tracks.length;
  };

  const normalizeVolume = (value) => {
    if (typeof value !== "number" || Number.isNaN(value)) {
      return DEFAULT_VOLUME;
    }

    return Math.min(MAX_VOLUME, Math.max(MIN_VOLUME, Math.round(value)));
  };

  const normalizeResumeTime = (value) => {
    if (typeof value !== "number" || Number.isNaN(value) || value < 0) {
      return 0;
    }

    return value;
  };

  const normalizeState = (candidate) => {
    const base = createState();
    if (!candidate || typeof candidate !== "object") {
      return base;
    }

    const playlistId = normalizePlaylistId(candidate.playlistId);
    return {
      playlistId,
      trackIndex: normalizeTrackIndex(playlistId, candidate.trackIndex),
      volume: normalizeVolume(candidate.volume),
      isPlaying: Boolean(candidate.isPlaying),
      resumeTime: normalizeResumeTime(candidate.resumeTime),
      isClosed: Boolean(candidate.isClosed),
    };
  };

  const loadState = () => {
    try {
      const raw = window.localStorage.getItem(STORAGE_KEY);
      if (!raw) {
        return null;
      }
      return normalizeState(JSON.parse(raw));
    } catch {
      return null;
    }
  };

  const store =
    window[GLOBAL_KEY] ??
    ({
      player: null,
      state: loadState() ?? createState(),
      dom: {},
      handlers: null,
      scriptInjected: false,
      ytHooked: false,
      routerHooked: false,
      resizeHooked: false,
      visibilityHooked: false,
      statusOverride: null,
    });

  store.state = normalizeState(store.state ?? loadState() ?? createState());
  window[GLOBAL_KEY] = store;

  const persistState = () => {
    try {
      window.localStorage.setItem(STORAGE_KEY, JSON.stringify(store.state));
    } catch {
      // Ignore storage write errors.
    }
  };

  const findPlayerRoot = (preferredRoot) => {
    if (preferredRoot instanceof HTMLElement && preferredRoot.isConnected) {
      return preferredRoot;
    }

    const rootNode = document.getElementById(PLAYER_DOM_IDS.root);
    return rootNode instanceof HTMLElement ? rootNode : null;
  };

  const getNodes = (preferredRoot) => {
    const rootNode = findPlayerRoot(preferredRoot);

    return {
      rootNode,
      playerNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.player}`) ?? null,
      volumeNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.volume}`) ?? null,
      toggleNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.toggle}`) ?? null,
      rewindNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.rewind}`) ?? null,
      skipNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.skip}`) ?? null,
      trackNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.track}`) ?? null,
      statusNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.status}`) ?? null,
      closeNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.close}`) ?? null,
      reopenNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.reopen}`) ?? null,
      genreNode: rootNode?.querySelector(`#${PLAYER_DOM_IDS.genre}`) ?? null,
    };
  };

  const getCurrentTrack = () => {
    const tracks = getTracks(store.state.playlistId);
    return tracks[store.state.trackIndex] ?? tracks[0] ?? null;
  };

  const updateToggle = () => {
    if (store.dom.toggleNode) {
      store.dom.toggleNode.textContent = store.state.isPlaying ? "Pause" : "Play";
    }
  };

  const updateTrackTitle = () => {
    const track = getCurrentTrack();
    if (store.dom.trackNode) {
      store.dom.trackNode.textContent = track ? track.title : "No track available";
    }
  };

  const updateStatus = () => {
    if (!store.dom.statusNode) {
      return;
    }

    if (store.statusOverride) {
      store.dom.statusNode.textContent = store.statusOverride;
      return;
    }

    const track = getCurrentTrack();
    if (!track) {
      store.dom.statusNode.textContent = "No tracks available";
      return;
    }

    store.dom.statusNode.textContent = store.state.isPlaying
      ? `Playing: ${track.title}`
      : `Ready: ${track.title}`;
  };

  const setStatusOverride = (message) => {
    store.statusOverride = message;
    updateStatus();
  };

  const ensureGenreOptions = () => {
    if (!store.dom.genreNode) {
      return;
    }

    const marker = PLAYLIST_IDS.join("|");
    if (
      store.dom.genreNode.dataset.playlists === marker &&
      store.dom.genreNode.options.length === PLAYLIST_IDS.length
    ) {
      store.dom.genreNode.value = store.state.playlistId;
      return;
    }

    store.dom.genreNode.innerHTML = "";
    PLAYLIST_IDS.forEach((playlistId) => {
      const option = document.createElement("option");
      option.value = playlistId;
      option.textContent = PLAYLISTS[playlistId]?.label ?? playlistId;
      store.dom.genreNode.appendChild(option);
    });

    store.dom.genreNode.dataset.playlists = marker;
    store.dom.genreNode.value = store.state.playlistId;
  };

  const getPlayingStateFromPlayer = () => {
    if (!store.player || typeof store.player.getPlayerState !== "function") {
      return null;
    }

    if (!window.YT || !window.YT.PlayerState) {
      return null;
    }

    const state = store.player.getPlayerState();
    if (state === window.YT.PlayerState.PLAYING || state === window.YT.PlayerState.BUFFERING) {
      return true;
    }

    if (
      state === window.YT.PlayerState.PAUSED ||
      state === window.YT.PlayerState.CUED ||
      state === window.YT.PlayerState.ENDED
    ) {
      return false;
    }

    // UNSTARTED (-1) is intentionally excluded above and falls through to `null`.
    // When transition:persist transplants the section between documents via
    // adoptNode(), the YT iframe can transiently report UNSTARTED even while
    // the video is mid-play.  Returning null tells syncIsPlayingFromPlayer()
    // to leave store.state.isPlaying untouched so the value snapshot() saved
    // in astro:before-swap remains authoritative.

    return null;
  };

  const syncIsPlayingFromPlayer = () => {
    const isPlaying = getPlayingStateFromPlayer();
    if (isPlaying === null) {
      return false;
    }

    store.state.isPlaying = isPlaying;
    updateToggle();
    updateStatus();
    return true;
  };

  const applyVisibility = () => {
    const rootNode = store.dom.rootNode ?? findPlayerRoot();
    if (!rootNode) {
      return;
    }

    const isMobile =
      typeof window.matchMedia === "function" && window.matchMedia(MOBILE_MEDIA_QUERY).matches;

    if (!isMobile) {
      store.state.isClosed = false;
      rootNode.removeAttribute("data-stereo-closed");
      return;
    }

    if (store.state.isClosed) {
      rootNode.setAttribute("data-stereo-closed", "true");
    } else {
      rootNode.removeAttribute("data-stereo-closed");
    }
  };

  const setVolume = (value, options = {}) => {
    const normalized = normalizeVolume(value);
    store.state.volume = normalized;
    if (store.dom.volumeNode) {
      store.dom.volumeNode.value = String(normalized);
    }
    if (store.player && typeof store.player.setVolume === "function") {
      store.player.setVolume(normalized);
    }

    if (options.persist !== false) {
      persistState();
    }
  };

  const snapshot = () => {
    if (store.player && typeof store.player.getCurrentTime === "function") {
      store.state.resumeTime = normalizeResumeTime(Number(store.player.getCurrentTime()));
    }
    syncIsPlayingFromPlayer();
    persistState();
  };

  const loadTrack = (index, options = {}) => {
    const playlistId = normalizePlaylistId(store.state.playlistId);
    const tracks = getTracks(playlistId);
    if (!tracks.length) {
      setStatusOverride("No tracks available");
      return;
    }

    const normalizedIndex = normalizeTrackIndex(playlistId, index);
    store.state.trackIndex = normalizedIndex;
    store.state.resumeTime = normalizeResumeTime(options.startAtSeconds ?? 0);
    persistState();

    updateTrackTitle();
    updateStatus();

    if (!store.player) {
      return;
    }

    const track = tracks[normalizedIndex];
    const request =
      store.state.resumeTime > 0
        ? { videoId: track.videoId, startSeconds: store.state.resumeTime }
        : track.videoId;

    if (options.autoplay) {
      store.player.loadVideoById(request);
      return;
    }

    if (typeof store.player.cueVideoById === "function") {
      store.player.cueVideoById(request);
      return;
    }

    store.player.loadVideoById(request);
    if (typeof store.player.pauseVideo === "function") {
      store.player.pauseVideo();
    }
  };

  const jumpTrack = (step) => {
    store.statusOverride = null;
    const nextIndex = normalizeTrackIndex(store.state.playlistId, store.state.trackIndex + step);
    loadTrack(nextIndex, { autoplay: store.state.isPlaying, startAtSeconds: 0 });
  };

  const changePlaylist = (playlistId) => {
    store.state.playlistId = normalizePlaylistId(playlistId);
    store.state.trackIndex = 0;
    store.state.resumeTime = 0;
    store.statusOverride = null;
    ensureGenreOptions();
    loadTrack(store.state.trackIndex, { autoplay: store.state.isPlaying, startAtSeconds: 0 });
  };

  const play = () => {
    if (!store.player || typeof store.player.playVideo !== "function") {
      setStatusOverride("Player unavailable");
      store.state.isPlaying = false;
      updateToggle();
      return;
    }

    store.statusOverride = null;
    store.player.playVideo();
    store.state.isPlaying = true;
    updateToggle();
    updateStatus();
    persistState();
  };

  const pause = () => {
    if (!store.player || typeof store.player.pauseVideo !== "function") {
      setStatusOverride("Player unavailable");
      store.state.isPlaying = false;
      updateToggle();
      return;
    }

    store.player.pauseVideo();
    store.state.isPlaying = false;
    updateToggle();
    updateStatus();
    persistState();
  };

  const togglePlayback = () => {
    if (!store.player) {
      setStatusOverride("Player unavailable");
      store.state.isPlaying = false;
      updateToggle();
      return;
    }

    const isPlaying = getPlayingStateFromPlayer();
    if (isPlaying === null ? store.state.isPlaying : isPlaying) {
      pause();
      return;
    }

    play();
  };

  const closePlayer = () => {
    store.state.isClosed = true;
    store.statusOverride = "Paused";
    pause();
    applyVisibility();
    persistState();
  };

  const reopenPlayer = () => {
    store.state.isClosed = false;
    store.statusOverride = null;
    applyVisibility();
    updateStatus();
    persistState();
  };

  const updateUI = () => {
    if (store.dom.volumeNode) {
      store.dom.volumeNode.value = String(store.state.volume);
    }

    ensureGenreOptions();
    updateTrackTitle();
    applyVisibility();

    if (!syncIsPlayingFromPlayer()) {
      updateToggle();
      updateStatus();
    }
  };

  const bindDom = () => {
    const previousDom = store.dom;
    const nextDom = getNodes(previousDom.rootNode);

    if (!store.handlers) {
      store.handlers = {
        onVolumeInput: () => {
          if (store.dom.volumeNode) {
            setVolume(Number(store.dom.volumeNode.value));
          }
        },
        onToggleClick: togglePlayback,
        onRewindClick: () => jumpTrack(-1),
        onSkipClick: () => jumpTrack(1),
        onGenreChange: () => {
          if (store.dom.genreNode) {
            changePlaylist(store.dom.genreNode.value);
          }
        },
        onCloseClick: closePlayer,
        onReopenClick: reopenPlayer,
      };
    }

    const bindingPlan = [
      { key: "volumeNode", eventName: "input", handlerName: "onVolumeInput" },
      { key: "toggleNode", eventName: "click", handlerName: "onToggleClick" },
      { key: "rewindNode", eventName: "click", handlerName: "onRewindClick" },
      { key: "skipNode", eventName: "click", handlerName: "onSkipClick" },
      { key: "genreNode", eventName: "change", handlerName: "onGenreChange" },
      { key: "closeNode", eventName: "click", handlerName: "onCloseClick" },
      { key: "reopenNode", eventName: "click", handlerName: "onReopenClick" },
    ];

    bindingPlan.forEach(({ key, eventName, handlerName }) => {
      const oldNode = previousDom[key];
      const newNode = nextDom[key];
      const handler = store.handlers[handlerName];

      if (oldNode && oldNode !== newNode) {
        oldNode.removeEventListener(eventName, handler);
      }

      if (newNode && oldNode !== newNode) {
        newNode.addEventListener(eventName, handler);
      }
    });

    store.dom = nextDom;
    updateUI();
  };

  const onReady = (event) => {
    setVolume(store.state.volume, { persist: false });
    loadTrack(store.state.trackIndex, {
      autoplay: store.state.isPlaying,
      startAtSeconds: store.state.resumeTime,
    });
    window.setTimeout(syncIsPlayingFromPlayer, 300);
  };

  const onStateChange = (event) => {
    if (!window.YT || !window.YT.PlayerState) {
      return;
    }

    if (event.data === window.YT.PlayerState.PLAYING) {
      store.state.isPlaying = true;
      store.statusOverride = null;
      updateToggle();
      updateStatus();
      persistState();
      return;
    }

    if (event.data === window.YT.PlayerState.PAUSED || event.data === window.YT.PlayerState.CUED) {
      store.state.isPlaying = false;
      updateToggle();
      updateStatus();
      snapshot();
      return;
    }

    if (event.data === window.YT.PlayerState.ENDED) {
      jumpTrack(1);
    }
  };

  const mountPlayer = () => {
    if (!store.dom.playerNode) {
      setStatusOverride("Audio blocked");
      return;
    }

    const hasMountedIframe = Boolean(store.dom.playerNode.querySelector("iframe"));

    if (store.player && typeof store.player.getPlayerState === "function" && hasMountedIframe) {
      syncIsPlayingFromPlayer();
      updateUI();
      return;
    }

    if (!window.YT || !window.YT.Player) {
      setStatusOverride("Audio blocked");
      return;
    }

    const track = getCurrentTrack();
    if (!track) {
      setStatusOverride("No tracks available");
      return;
    }

    store.player = new window.YT.Player(store.dom.playerNode, {
      height: "1",
      width: "1",
      videoId: track.videoId,
      playerVars: {
        autoplay: 0,
        controls: 0,
        disablekb: 1,
        fs: 0,
        iv_load_policy: 3,
        modestbranding: 1,
        playsinline: 1,
        rel: 0,
      },
      events: {
        onReady,
        onStateChange,
      },
    });
  };

  const bootstrapPlayer = () => {
    bindDom();

    if (window.YT && window.YT.Player) {
      mountPlayer();
      return;
    }

    if (!store.ytHooked) {
      const previousReadyHook = window.onYouTubeIframeAPIReady;
      window.onYouTubeIframeAPIReady = () => {
        if (typeof previousReadyHook === "function") {
          previousReadyHook();
        }
        mountPlayer();
      };
      store.ytHooked = true;
    }

    if (!store.scriptInjected) {
      const youtubeScript = document.createElement("script");
      youtubeScript.src = "https://www.youtube.com/iframe_api";
      document.head.appendChild(youtubeScript);
      store.scriptInjected = true;
    }
  };

  if (!store.routerHooked) {
    document.addEventListener("astro:before-swap", snapshot);
    document.addEventListener("astro:after-swap", () => {
      // Capture isPlaying BEFORE bindDom() runs.  bindDom() -> updateUI() ->
      // syncIsPlayingFromPlayer() can read a transient UNSTARTED state from
      // the YT player right after document adoption and would write false into
      // store.state.isPlaying, discarding the accurate value snapshot() saved
      // moments ago in astro:before-swap.
      const wasPlaying = store.state.isPlaying;

      bindDom();

      // Restore the authoritative value in case syncIsPlayingFromPlayer() ran
      // during bindDom/updateUI and wrote a bad state from a transitional
      // player reading.
      store.state.isPlaying = wasPlaying;

      mountPlayer();

      // Only call playVideo() directly when the iframe is already mounted.
      // If transition:persist kept it alive (the normal case) the iframe is
      // there and we resume immediately.  If mountPlayer() is constructing a
      // fresh YT.Player (transition:persist failed / first visit after a gap),
      // the player is not ready yet and playVideo() would silently no-op;
      // onReady() handles autoplay in that path using store.state.isPlaying,
      // which is correctly preserved above.
      const hasIframe = Boolean(store.dom.playerNode?.querySelector("iframe"));
      if (wasPlaying && hasIframe && store.player && typeof store.player.playVideo === "function") {
        store.player.playVideo();
        window.setTimeout(syncIsPlayingFromPlayer, 300);
      }
    });
    store.routerHooked = true;
  }

  if (!store.resizeHooked) {
    window.addEventListener("resize", applyVisibility);
    store.resizeHooked = true;
  }

  if (!store.visibilityHooked) {
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden") {
        snapshot();
      }
    });
    window.addEventListener("pagehide", snapshot);
    store.visibilityHooked = true;
  }

  bootstrapPlayer();
</script>

<style>
  .stereo-player {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 55;
    width: min(23rem, calc(100vw - 2rem));
  }

  .stereo-shell {
    border: 1px solid rgba(215, 215, 215, 0.48);
    background:
      linear-gradient(180deg, rgba(4, 7, 10, 0.97), rgba(11, 17, 24, 0.95)),
      radial-gradient(circle at top, rgba(215, 215, 215, 0.16), transparent 50%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08) inset,
      0 0 22px rgba(var(--site-accent-rgb), 0.12),
      0 18px 30px rgba(0, 0, 0, 0.36);
    padding: 0.85rem;
    position: relative;
    overflow: hidden;
  }

  .stereo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .stereo-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.05) 0,
      rgba(255, 255, 255, 0.05) 1px,
      transparent 1px,
      transparent 3px
    );
    background-size: 100% 3px;
    opacity: 0.08;
    pointer-events: none;
  }

  .stereo-title {
    color: #ffffff;
    font-size: 0.515rem;
    letter-spacing: 0.14em;
    margin: 0;
  }

  .stereo-track {
    color: var(--site-accent-color);
    font-size: 0.74rem;
    margin-top: 0.2rem;
    margin-bottom: 0.65rem;
    min-height: 1.15rem;
  }

  .stereo-controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
