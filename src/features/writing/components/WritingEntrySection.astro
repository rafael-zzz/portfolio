---
import SectionFrame from "@/shared/ui/SectionFrame.astro";
import SectionHeader from "@/shared/ui/SectionHeader.astro";
import LocalizedFallbackNotice from "@/shared/ui/LocalizedFallbackNotice.astro";
import type { Messages } from "@/i18n/schema";
import type { LocalizedContent } from "@/shared/lib/localizedContent";
import type { WritingEntry } from "@/features/writing/lib/content";
import { getSourceSlug } from "@/shared/lib/contentSlug";

interface Props {
  entry: LocalizedContent<WritingEntry>;
  fallbackCopy: Messages["contentFallback"];
  tagsLabel: string;
}

const { entry, fallbackCopy, tagsLabel } = Astro.props;
const { Content } = await entry.entry.render();
const safeFontScale = Math.min(Math.max(entry.entry.data.fontScale, 0.85), 1.45);
const publishedDateIso = entry.entry.data.publishedAt.toISOString().slice(0, 10);
const sourceSlug = getSourceSlug(entry.entry);
const sourceLocale = entry.contentLocale;
const zineIssue = String(entry.entry.data.publishedAt.getUTCMonth() + 1).padStart(2, "0");
const zineFileCode = sourceSlug.replace(/[^a-z0-9-]/gi, "-").toUpperCase();
---

<SectionFrame>
  <SectionHeader title={entry.entry.data.title} eyebrow={`/writing/${sourceSlug}`} />

  {
    entry.isFallback && (
      <LocalizedFallbackNotice copy={fallbackCopy} contentLocale={entry.contentLocale} />
    )
  }

  <div class="writing-terminal-shell font-['Departure_Mono']">
    <span class="writing-terminal-label">raf@portfolio:~$</span>
    <span class="writing-terminal-command">cat /content/writing/{sourceLocale}/{sourceSlug}.md</span
    >
  </div>

  <div class="writing-zine-masthead font-['Departure_Mono']">
    <p class="writing-zine-kicker">TERMINAL EDITION // PERSONAL RESEARCH FILE</p>
    <div class="writing-zine-grid">
      <span>ISS.{zineIssue}</span>
      <span>FILE.{zineFileCode}</span>
      <time datetime={entry.entry.data.publishedAt.toISOString()}>{publishedDateIso}</time>
    </div>
    <p class="writing-zine-description">{entry.entry.data.description}</p>
  </div>

  <div class="writing-tags">
    <span class="writing-tags-label font-['Departure_Mono']">{tagsLabel}</span>
    <div class="writing-tag-list font-['Departure_Mono']">
      {entry.entry.data.tags.map((tag: string) => <span>{`--${tag}`}</span>)}
    </div>
  </div>

  <article class="writing-post-content" style={`--writing-font-scale: ${safeFontScale};`}>
    <Content />
  </article>
</SectionFrame>

<style>
  .writing-terminal-shell {
    align-items: center;
    background:
      linear-gradient(90deg, rgba(7, 28, 46, 0.78), rgba(7, 28, 46, 0.22)), rgba(2, 12, 24, 0.93);
    border: 1px solid rgba(132, 230, 255, 0.38);
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.9rem 1rem 0;
    padding: 0.5rem 0.7rem 0.52rem;
  }

  .writing-terminal-label {
    color: rgba(182, 240, 255, 0.96);
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .writing-terminal-command {
    color: rgba(223, 248, 255, 0.97);
    font-size: 0.63rem;
    letter-spacing: 0.05em;
    overflow-wrap: anywhere;
  }

  .writing-zine-masthead {
    background:
      linear-gradient(90deg, rgba(137, 230, 255, 0.16), rgba(137, 230, 255, 0.03)),
      rgba(2, 10, 21, 0.9);
    border: 1px solid rgba(132, 230, 255, 0.34);
    margin: 0.5rem 1rem 0;
    overflow: hidden;
    padding: 0.85rem 0.95rem 0.95rem;
    position: relative;
  }

  .writing-zine-masthead::after {
    border-bottom: 1px dashed rgba(132, 230, 255, 0.58);
    bottom: 0.45rem;
    content: "";
    left: 0.9rem;
    position: absolute;
    right: 0.9rem;
  }

  .writing-zine-kicker {
    color: rgba(198, 244, 255, 0.94);
    font-size: 0.64rem;
    letter-spacing: 0.18em;
    margin: 0;
    text-transform: uppercase;
  }

  .writing-zine-grid {
    color: rgba(179, 239, 255, 0.95);
    display: grid;
    gap: 0.35rem 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    margin-top: 0.66rem;
    text-transform: uppercase;
  }

  .writing-zine-grid span,
  .writing-zine-grid time {
    border: 1px dashed rgba(132, 230, 255, 0.44);
    font-size: 0.66rem;
    letter-spacing: 0.13em;
    line-height: 1.4;
    padding: 0.26rem 0.4rem;
  }

  .writing-zine-description {
    color: rgba(220, 245, 255, 0.88);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    line-height: 1.6;
    margin: 0.74rem 0 0.95rem;
    text-transform: uppercase;
  }

  .writing-tags {
    align-items: center;
    border-bottom: 1px solid rgba(132, 230, 255, 0.2);
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 0 1rem;
    padding: 0.8rem 0.1rem 0.9rem;
  }

  .writing-tags-label {
    color: rgba(179, 239, 255, 0.84);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .writing-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .writing-tag-list span {
    border: 1px dashed rgba(132, 230, 255, 0.38);
    color: rgba(212, 247, 255, 0.93);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    padding: 0.18rem 0.42rem;
    text-transform: uppercase;
  }

  .writing-post-content {
    --writing-font-scale: 1;
    background: linear-gradient(180deg, rgba(3, 10, 19, 0.86), rgba(2, 7, 13, 0.96));
    border: 1px solid rgba(132, 230, 255, 0.24);
    box-shadow: inset 0 1px 0 rgba(194, 245, 255, 0.08);
    color: rgba(224, 247, 255, 0.95);
    counter-reset: terminal-section terminal-subsection;
    font-family:
      "JetBrains Mono", "Cascadia Mono", "SFMono-Regular", Menlo, Monaco, Consolas,
      "Liberation Mono", "Courier New", monospace;
    font-size: calc(0.98rem * var(--writing-font-scale));
    line-height: 1.8;
    letter-spacing: 0.01em;
    margin: 1rem auto 1.2rem;
    max-width: 76ch;
    overflow: hidden;
    padding: 1.35rem clamp(1rem, 2.3vw, 1.7rem) 1.6rem;
    position: relative;
  }

  .writing-post-content::before {
    background: repeating-linear-gradient(
      180deg,
      rgba(133, 229, 255, 0.05) 0,
      rgba(133, 229, 255, 0.05) 1px,
      transparent 1px,
      transparent 3px
    );
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .writing-post-content :global(h1),
  .writing-post-content :global(h2),
  .writing-post-content :global(h3),
  .writing-post-content :global(h4) {
    color: #e9f8ff;
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    letter-spacing: 0.03em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    margin-top: 1.55rem;
    text-wrap: balance;
  }

  .writing-post-content :global(h1) {
    font-size: 1.5em;
  }

  .writing-post-content :global(h2) {
    counter-increment: terminal-section;
    counter-reset: terminal-subsection;
    font-size: 1.24em;
  }

  .writing-post-content :global(h2)::before {
    color: rgba(163, 238, 255, 0.97);
    content: "$ section-" counter(terminal-section, decimal-leading-zero) " > ";
    font-family: "Departure Mono", monospace;
    font-size: 0.52em;
    letter-spacing: 0.15em;
    margin-right: 0.4rem;
    vertical-align: 0.16em;
  }

  .writing-post-content :global(h3) {
    counter-increment: terminal-subsection;
    font-size: 1.08em;
  }

  .writing-post-content :global(h3)::before {
    color: rgba(142, 228, 255, 0.85);
    content: ">> " counter(terminal-section, decimal-leading-zero) "." counter(terminal-subsection)
      " ";
    font-family: "Departure Mono", monospace;
    font-size: 0.66em;
    letter-spacing: 0.08em;
    margin-right: 0.25rem;
    vertical-align: 0.15em;
  }

  .writing-post-content :global(h4) {
    font-size: 1em;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .writing-post-content :global(p) {
    margin-bottom: 0;
    margin-top: 1rem;
    text-wrap: pretty;
  }

  .writing-post-content :global(p:first-of-type)::first-letter {
    color: inherit;
    float: none;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    margin-right: 0;
    margin-top: 0;
  }

  .writing-post-content :global(p:first-of-type)::before {
    color: rgba(163, 238, 255, 0.86);
    content: "[boot] ";
    font-family: "Departure Mono", monospace;
    letter-spacing: 0.06em;
  }

  .writing-post-content :global(ul),
  .writing-post-content :global(ol) {
    margin-bottom: 0;
    margin-top: 1rem;
    padding-left: 1.3rem;
  }

  .writing-post-content :global(li + li) {
    margin-top: 0.45rem;
  }

  .writing-post-content :global(li > p:first-child) {
    margin-top: 0;
  }

  .writing-post-content :global(a) {
    color: #84e6ff;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-style: dotted;
    text-underline-offset: 0.15em;
  }

  .writing-post-content :global(a:hover) {
    color: #d7f6ff;
  }

  .writing-post-content :global(strong) {
    color: #f3fbff;
    font-weight: 600;
  }

  .writing-post-content :global(blockquote) {
    background:
      linear-gradient(90deg, rgba(9, 26, 46, 0.38), rgba(9, 26, 46, 0.08)), rgba(4, 14, 28, 0.72);
    border-left: 3px solid rgba(132, 230, 255, 0.64);
    margin-bottom: 0;
    margin-top: 1.1rem;
    padding: 0.9rem 0.95rem;
  }

  .writing-post-content :global(blockquote p:first-child) {
    margin-top: 0;
  }

  .writing-post-content :global(blockquote.md-callout) {
    border: 1px solid rgba(132, 230, 255, 0.4);
    border-left-width: 4px;
    padding-top: 1.9rem;
    position: relative;
  }

  .writing-post-content :global(blockquote.md-callout)::before {
    color: rgba(198, 244, 255, 0.96);
    content: attr(data-callout);
    font-size: 0.68em;
    font-weight: 600;
    left: 0.9rem;
    letter-spacing: 0.16em;
    position: absolute;
    text-transform: uppercase;
    top: 0.6rem;
  }

  .writing-post-content :global(blockquote.md-callout-note),
  .writing-post-content :global(blockquote.md-callout-info) {
    background: rgba(5, 20, 34, 0.72);
    border-left-color: rgba(132, 230, 255, 0.9);
  }

  .writing-post-content :global(blockquote.md-callout-tip) {
    background: rgba(5, 32, 42, 0.71);
    border-left-color: rgba(166, 241, 255, 0.96);
  }

  .writing-post-content :global(blockquote.md-callout-warning),
  .writing-post-content :global(blockquote.md-callout-caution) {
    background: rgba(52, 42, 9, 0.74);
    border-left-color: rgba(255, 200, 107, 0.96);
  }

  .writing-post-content :global(blockquote.md-callout-danger) {
    background: rgba(58, 12, 18, 0.72);
    border-left-color: rgba(255, 123, 142, 0.95);
  }

  .writing-post-content :global(code) {
    background: rgba(5, 16, 28, 0.92);
    border: 1px solid rgba(132, 230, 255, 0.28);
    color: rgba(214, 248, 255, 0.96);
    font-family: "Departure Mono", "JetBrains Mono", "Cascadia Mono", monospace;
    font-size: 0.9em;
    padding: 0.11em 0.34em;
  }

  .writing-post-content :global(pre) {
    background: rgba(2, 10, 20, 0.95);
    border: 1px solid rgba(132, 230, 255, 0.31);
    margin-bottom: 0;
    margin-top: 1.1rem;
    overflow-x: auto;
    padding: 0.85rem;
    position: relative;
  }

  .writing-post-content :global(pre)::before {
    color: rgba(163, 238, 255, 0.95);
    content: "code";
    font-family: "Departure Mono", monospace;
    font-size: 0.6rem;
    left: 0.75rem;
    letter-spacing: 0.14em;
    position: absolute;
    text-transform: uppercase;
    top: 0.4rem;
  }

  .writing-post-content :global(pre code) {
    background: transparent;
    border: 0;
    display: block;
    font-family: "Departure Mono", "JetBrains Mono", "Cascadia Mono", monospace;
    font-size: 0.9em;
    line-height: 1.72;
    padding: 0.58rem 0 0;
    white-space: pre;
  }

  .writing-post-content :global(hr) {
    border: 0;
    border-top: 1px dashed rgba(132, 230, 255, 0.54);
    margin-bottom: 0;
    margin-top: 1.35rem;
  }

  .writing-post-content :global(table) {
    border-collapse: collapse;
    display: block;
    margin-bottom: 0;
    margin-top: 1.1rem;
    max-width: 100%;
    overflow-x: auto;
    width: 100%;
  }

  .writing-post-content :global(th),
  .writing-post-content :global(td) {
    border: 1px solid rgba(132, 230, 255, 0.34);
    padding: 0.42rem 0.58rem;
    text-align: left;
  }

  .writing-post-content :global(th) {
    background: rgba(5, 18, 29, 0.9);
    color: rgba(212, 247, 255, 0.95);
    letter-spacing: 0.03em;
  }

  .writing-post-content :global(details) {
    background: rgba(4, 16, 28, 0.72);
    border: 1px dashed rgba(132, 230, 255, 0.42);
    margin-bottom: 0;
    margin-top: 1.1rem;
    padding: 0.8rem 0.9rem;
  }

  .writing-post-content :global(summary) {
    color: rgba(179, 239, 255, 0.94);
    cursor: pointer;
    font-size: 0.95em;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .writing-post-content :global(details > :not(summary)) {
    margin-top: 0.7rem;
  }

  .writing-post-content :global(img) {
    border: 1px solid rgba(132, 230, 255, 0.36);
    margin-bottom: 0;
    margin-top: 1.1rem;
    max-width: 100%;
  }

  .writing-post-content :global(ul.contains-task-list) {
    list-style: none;
    padding-left: 0;
  }

  .writing-post-content :global(li.task-list-item) {
    align-items: flex-start;
    display: flex;
    gap: 0.45rem;
  }

  .writing-post-content :global(li.task-list-item input[type="checkbox"]) {
    accent-color: #84e6ff;
    margin-top: 0.34rem;
  }

  .writing-post-content :global(.footnotes) {
    border-top: 1px dashed rgba(132, 230, 255, 0.42);
    margin-top: 1.4rem;
    padding-top: 1rem;
  }

  .writing-post-content :global(.zine-pull) {
    border-inline: 1px solid rgba(132, 230, 255, 0.35);
    color: rgba(211, 246, 255, 0.97);
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 1.06em;
    letter-spacing: 0.02em;
    margin: 1.2rem 0;
    padding: 0.75rem 0.95rem;
    text-align: center;
  }

  .writing-post-content :global(.zine-gloss) {
    color: rgba(175, 222, 239, 0.89);
    font-family: "Departure Mono", monospace;
    font-size: 0.85em;
    letter-spacing: 0.03em;
    line-height: 1.6;
  }

  .writing-post-content :global([data-size="xs"]) {
    font-size: 0.78em;
  }

  .writing-post-content :global([data-size="sm"]) {
    font-size: 0.9em;
  }

  .writing-post-content :global([data-size="lg"]) {
    font-size: 1.12em;
  }

  .writing-post-content :global([data-size="xl"]) {
    font-size: 1.28em;
  }

  .writing-post-content :global([data-align="center"]) {
    text-align: center;
  }

  .writing-post-content :global([data-align="right"]) {
    text-align: right;
  }

  .writing-post-content :global(.md-lead) {
    color: rgba(236, 250, 255, 0.98);
    font-size: 1.08em;
    letter-spacing: 0.015em;
  }

  .writing-post-content :global(.md-muted) {
    opacity: 0.68;
  }

  .writing-post-content :global(.md-chip) {
    border: 1px solid rgba(132, 230, 255, 0.5);
    color: rgba(179, 239, 255, 0.95);
    display: inline-block;
    font-size: 0.74em;
    letter-spacing: 0.12em;
    padding: 0.15em 0.45em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .writing-terminal-shell {
      gap: 0.38rem;
      margin: 0.8rem 0.8rem 0;
      padding: 0.42rem 0.56rem;
    }

    .writing-terminal-label,
    .writing-terminal-command {
      font-size: 0.62rem;
    }

    .writing-zine-masthead {
      margin: 0.45rem 0.8rem 0;
      padding-inline: 0.75rem;
    }

    .writing-zine-description {
      font-size: 0.69rem;
      line-height: 1.55;
    }

    .writing-post-content {
      font-size: calc(0.92rem * var(--writing-font-scale));
      line-height: 1.74;
      margin: 0.9rem 0.8rem 1rem;
      max-width: none;
      padding: 1.1rem 0.9rem 1.25rem;
    }

    .writing-post-content :global(p:first-of-type)::before {
      font-size: 0.72em;
    }
  }
</style>
