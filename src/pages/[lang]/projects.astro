---
import SiteLayout from "@/features/chrome/components/SiteLayout.astro";
import ProjectsHubPage from "@/features/projects/components/ProjectsHubPage.astro";
import { getProjectsPageData } from "@/features/projects/model/getProjectsPageData";
import { isLocale, LOCALES } from "@/i18n";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const maybeLocale = Astro.params.lang;

if (!isLocale(maybeLocale)) {
  return Astro.redirect("/en/projects");
}

const pageData = await getProjectsPageData(maybeLocale);
---

<SiteLayout
  locale={pageData.locale}
  routeKey="projects"
  messages={pageData.messages}
  routeMeta={pageData.routeMeta}
>
  <ProjectsHubPage
    copy={pageData.messages.projects.page}
    fallbackCopy={pageData.messages.contentFallback}
    cards={pageData.cards}
    hasFallback={pageData.hasFallback}
  />
</SiteLayout>
