---
import { getCanonicalWritingSlugs } from "@/features/writing/lib/content";
import WritingEntrySection from "@/features/writing/components/WritingEntrySection.astro";
import { getWritingPageData } from "@/features/writing/model/getWritingPageData";
import SiteLayout from "@/features/chrome/components/SiteLayout.astro";
import { isLocale, LOCALES } from "@/i18n";

export async function getStaticPaths() {
  const slugs = await getCanonicalWritingSlugs();

  return LOCALES.flatMap((lang) =>
    slugs.map((slug) => ({
      params: { lang, slug },
    })),
  );
}

const maybeLocale = Astro.params.lang;
const slug = Astro.params.slug;

if (!isLocale(maybeLocale) || !slug) {
  return Astro.redirect("/en/");
}

const pageData = await getWritingPageData(maybeLocale, slug);

if (!pageData) {
  return Astro.redirect("/en/writing");
}
---

<SiteLayout
  locale={pageData.locale}
  routeKey="writing"
  messages={pageData.messages}
  routeMeta={pageData.routeMeta}
>
  <WritingEntrySection
    entry={pageData.entry}
    fallbackCopy={pageData.messages.contentFallback}
    tagsLabel={pageData.messages.writing.page.tagsLabel}
  />
</SiteLayout>
